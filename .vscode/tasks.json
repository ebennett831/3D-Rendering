{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Compile Java Project",
			"type": "shell",
			"command": "javac",
			"args": [
				"-d",
				"bin",
				"-cp",
				"src",
				"src/core/*.java",
				"src/math/*.java",
				"src/geometry/*.java"
			],
			"problemMatcher": [
				"$javac"
			],
			"group": "build"
		},
		{
			"label": "Run 3D Renderer",
			"type": "shell",
			"command": "java",
			"args": [
				"-cp",
				"bin",
				"core.Main"
			],
			"isBackground": false,
			"group": "test"
		}
	]
}